# Model config (required)
MODEL_API=anthropic
MODEL_NAME=claude-sonnet-4-5-20250929
MODEL_API_KEY=sk-ant-...

# Sub-agent model (for summarize and research tools)
# Defaults to Haiku. Leave SUB_MODEL_API_KEY empty to reuse MODEL_API_KEY.
SUB_MODEL_API=anthropic
SUB_MODEL_NAME=claude-haiku-4-5-20251001
SUB_MODEL_API_KEY=
# For Moonshot/Kimi:
# SUB_MODEL_API=openapi
# SUB_MODEL_NAME=kimi-2.5
# SUB_MODEL_ENDPOINT=https://api.moonshot.cn/v1
# SUB_MODEL_API_KEY=your-key

# Exa web search (optional)
EXA_API_KEY=

# Discord chat bot (optional)
# Creates chat sessions from threads in the configured channel. Bot token is
# set via the TUI Secrets screen as DISCORD_BOT_TOKEN; if that secret is
# missing, the bot simply doesn't start.
DISCORD_SESSIONS_CHANNEL=victrola-sessions

# Web UI (optional)
# Defaults to 127.0.0.1:8000. Set WEB_HOST to 0.0.0.0 to expose on all
# interfaces (e.g. reachable over Tailscale). When binding non-loopback, also
# list the hostname browsers will use in WEB_ALLOWED_HOSTS so same-origin
# (CSRF) checks pass — e.g. WEB_ALLOWED_HOSTS=pikachu for a Tailscale host.
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_ALLOWED_HOSTS=

# Compaction (optional)
# Character limit before the conversation is auto-compacted (~4 chars/token).
# Default: 240000 (~60k tokens).
# COMPACT_THRESHOLD_CHARS=240000

# MCP connections (optional)
# Seconds between background health-check pings to MCP servers. 0 disables.
# Default: 120 (2 minutes)
# MCP_HEALTH_CHECK_INTERVAL_SECONDS=120
# SSE read timeout for streamable_http transports, in seconds.
# Default: 1800 (30 minutes)
# MCP_SSE_READ_TIMEOUT_SECONDS=1800
